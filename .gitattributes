# Cross-platform line endings
* text=auto eol=lf
*.sh text eol=lf
*.mjs text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.env text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf
*.bat text eol=crlf
*.cmd text eol=crlf
# Never commit binary files
*.tar binary
*.tar.gz binary
*.tar.xz binary
*.zip binary
